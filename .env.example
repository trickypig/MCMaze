# Copy to .env and adjust for your machine. Used by `npm run local-deploy`.

# Folder name used under development_behavior_packs/ and development_resource_packs/.
PROJECT_NAME=trickymaze

# Which Minecraft install to deploy to:
#   BedrockUWP  — Microsoft Store "Minecraft"
#   PreviewUWP  — Microsoft Store "Minecraft Preview"
#   Custom      — use CUSTOM_DEPLOYMENT_PATH below (points to com.mojang)
MINECRAFT_PRODUCT=BedrockUWP

# Only used when MINECRAFT_PRODUCT=Custom. Absolute path to com.mojang.
# CUSTOM_DEPLOYMENT_PATH=C:\Users\you\AppData\Roaming\Minecraft Bedrock\Users\Shared\games\com.mojang
